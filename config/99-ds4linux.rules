# ds4linux udev rules
#
# 1. HIDE the physical DualSense / DualSense Edge from non-root users (Steam, etc.)
#    The daemon runs as root and has already opened these fds before udev runs.
KERNEL=="hidraw*", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0ce6", MODE="0600", TAG-="uaccess"
SUBSYSTEM=="input", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0ce6", MODE="0600", TAG-="uaccess"
KERNEL=="hidraw*", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0df2", MODE="0600", TAG-="uaccess"
SUBSYSTEM=="input", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0df2", MODE="0600", TAG-="uaccess"

# 2. REVEAL the Virtual DualShock 4 v2 (UHID device, PID 09CC)
#    UHID devices sit under the "hid" subsystem with KERNELS "0003:054C:09CC.*"
#    (bus 0003 = USB, vendor 054C, product 09CC).
#    Grant world-readable access so Proton/Wine winebus.sys can open the hidraw node.
KERNEL=="hidraw*", SUBSYSTEM=="hidraw", SUBSYSTEMS=="hid", KERNELS=="0003:054C:09CC.*", MODE="0666", TAG+="uaccess", ENV{ID_INPUT}="1", ENV{ID_INPUT_JOYSTICK}="1"
SUBSYSTEM=="input", KERNEL=="event*", SUBSYSTEMS=="hid", KERNELS=="0003:054C:09CC.*", MODE="0666", TAG+="uaccess", ENV{ID_INPUT}="1", ENV{ID_INPUT_JOYSTICK}="1"
