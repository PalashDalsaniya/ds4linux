# 1. HIDE the physical DualSense (Lock to root)
KERNEL=="hidraw*", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0ce6", MODE="0600", TAG-="uaccess"
SUBSYSTEM=="input", ATTRS{idVendor}=="054c", ATTRS{idProduct}=="0ce6", MODE="0600", TAG-="uaccess"

# 2. REVEAL the Virtual DualShock 4 (Match by exact DS4 name)
KERNEL=="hidraw*", ATTRS{name}=="Wireless Controller", MODE="0666"
SUBSYSTEM=="input", ATTRS{name}=="Wireless Controller", MODE="0666"
